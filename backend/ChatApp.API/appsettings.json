{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "https://localhost:4200",
      "app://."
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=chatapp;Username=postgres;Password=postgres;MaxPoolSize=100;Timeout=30;CommandTimeout=30;",
    "Redis": "localhost:6379,password=nexchat_redis_dev_2024,abortConnect=false,connectTimeout=5000,syncTimeout=5000",
    "Kafka": "localhost:29092"
  },
  "Jwt": {
    "Issuer": "ChatApp",
    "Audience": "ChatApp.Client",
    "KeyId": "chatapp-key-v1",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 30,
    "PrivateKeyPath": "/run/secrets/jwt_private_key",
    "PublicKeyPath": "/run/secrets/jwt_public_key"
  },
  "MinIO": {
    "Endpoint": "localhost:9000",
    "AccessKey": "nexchat_minio_admin",
    "SecretKey": "nexchat_minio_dev_2024",
    "UseSSL": false,
    "PublicUrl": "http://localhost:9000"
  },
  "Kafka": {
    "BootstrapServers": "localhost:29092",
    "GroupId": "chatapp-consumers",
    "EnableConsumers": true
  },
  "Twilio": {
    "AccountSid": "",
    "AuthToken": "",
    "FromNumber": ""
  },
  "Firebase": {
    "ProjectId": "",
    "CredentialsPath": "/run/secrets/firebase_credentials"
  },
  "ClamAv": {
    "Host": "localhost",
    "Port": 3310,
    "Enabled": false
  },
  "Smtp": {
    "Host": "localhost",
    "Port": 1025,
    "From": "noreply@chatapp.local",
    "EnableSsl": false
  },
  "Turn": {
    "Servers": [ "turn:localhost:3478" ],
    "Secret": "NexChat_TURN_S3cr3t_2024!",
    "Realm": "chatapp.local"
  },
  "Hangfire": {
    "Username": "admin",
    "Password": "hangfire_dev_2024"
  },
  "Elasticsearch": {
    "Uri": "http://localhost:9200",
    "Username": "elastic",
    "Password": ""
  },
  "Encryption": {
    "Key": ""
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  }
}