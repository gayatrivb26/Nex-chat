# ============================================================
# NexChat - .gitignore
# ============================================================

# --- Secrets (NEVER COMMIT) ---
secrets/
!secrets/.gitignore
!secrets/README.md
.env
.env.local
.env.production

# --- Docker ---
*.env.override

# --- .NET ---
.vs/
backend/**/bin/
backend/**/obj/
backend/**/*.user
backend/**/*.suo
backend/.vs/
backend/**/TestResults/
backend/**/*.log

# --- Node / Angular ---
frontend/node_modules/
frontend/dist/
frontend/.angular/
frontend/.env
frontend/*.log

# --- Electron ---
frontend/electron/dist/
frontend/electron/build/
frontend/out/

# --- OS ---
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# --- Editor ---
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.iml

# --- Logs ---
*.log
logs/
infrastructure/nginx/ssl/*.pem
infrastructure/nginx/ssl/*.crt
infrastructure/nginx/ssl/*.key

# --- Generated ---
infrastructure/grafana/dashboards/*.generated.json
